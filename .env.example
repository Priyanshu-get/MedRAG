# ==========================================
# LLM Configuration
# ==========================================
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=claude-sonnet-4-20250514

# Embedding: "openai" or "local" (BAAI/bge-large-en-v1.5 — free, no API key needed)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
LOCAL_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# ==========================================
# Vector Database (Qdrant — self-hosted)
# ==========================================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=medrag_docs
# 3072 for text-embedding-3-large, 1024 for BAAI/bge-large-en-v1.5
QDRANT_VECTOR_SIZE=3072

# ==========================================
# PostgreSQL (metadata + full-text search)
# ==========================================
DATABASE_URL=postgresql+asyncpg://medrag_user:medrag_pass@localhost:5432/medrag

# ==========================================
# Redis (query cache + Celery broker)
# ==========================================
REDIS_URL=redis://localhost:6379
CACHE_TTL_SECONDS=3600

# ==========================================
# NCBI / PubMed (free API key at ncbi.nlm.nih.gov/account/)
# ==========================================
NCBI_API_KEY=your_ncbi_api_key_here
NCBI_EMAIL=your_email@example.com

# ==========================================
# Semantic Scholar (optional — increases rate limits)
# ==========================================
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_key_here

# ==========================================
# RAG Pipeline Thresholds
# ==========================================
MAX_RETRIEVED_CHUNKS=20
RERANK_TOP_K=5
SIMILARITY_THRESHOLD=0.72
HALLUCINATION_CONFIDENCE_THRESHOLD=0.65
MAX_CONTEXT_TOKENS=8000

# ==========================================
# Application Settings
# ==========================================
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
